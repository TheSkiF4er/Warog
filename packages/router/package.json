{
  "name": "@warog/router",
  "version": "0.4.0",
  "description": "Signal-first routing for Warog",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "repository": {
    "type": "git",
    "url": "https://github.com/example/warog.git",
    "directory": "packages/router"
  },
  "homepage": "https://github.com/example/warog#readme",
  "bugs": {
    "url": "https://github.com/example/warog/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/index.test.js"
  },
  "dependencies": {
    "@warog/core": "file:../core",
    "@warog/dom": "file:../dom"
  }
}
